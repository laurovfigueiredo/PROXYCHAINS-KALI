BLOCO 1 — INSTALAÇÃO E CONFIGURAÇÃO DO PROXYCHAINS + TOR
----------------------------------------------------------------

# Instalar proxychains4 e Tor
sudo apt update && sudo apt install proxychains4 tor -y

# Iniciar o Tor
sudo systemctl start tor@default

# Habilitar Tor no boot
sudo systemctl enable tor

# Verificar se o Tor está rodando
sudo systemctl status tor@default

# Confirmar porta 9050 ativa
ss -tlnp | grep 9050


----------------------------------------------------------------
BLOCO 2 — CONFIGURAÇÃO DO /etc/proxychains4.conf
----------------------------------------------------------------

sudo nano /etc/proxychains4.conf

# O arquivo deve ter EXATAMENTE estas linhas descomentadas:

  dynamic_chain           ← linha ~10 (descomentada) 
  proxy_dns              ← linha ~60 (descomentada)

  [ProxyList]

  socks5 127.0.0.1 9050     ← única linha ativa na lista
# Tudo mais deve estar comentado com #
# Salvar: Ctrl+O → Enter → Ctrl+X

# Verificar se o config está correto
grep -n "dynamic_chain\|socks5\|proxy_dns" /etc/proxychains4.conf


